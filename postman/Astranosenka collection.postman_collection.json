        {
          "name": "Registration - Valid",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const moment = require('moment');\r",
                  "\r",
                  "const randomLetters = pm.variables.replaceIn('{{$randomAlphabeticSearchTerm}}').toLowerCase().substring(0, 10);\r",
                  "pm.environment.set(\"userName\", \"Uladzislau\" + randomLetters);\r",
                  "pm.environment.set(\"userSurname\", \"Astranosenka\" + randomLetters);\r",
                  "\r",
                  "let currentDate = moment().format(\"YYYY-MM-DDTHH-mm-ss\");\r",
                  "pm.environment.set(\"userEmail\", \"vladostronosenko\" + \"+\" + currentDate + \"@mail.ru\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "var jsonData = pm.response.json();\r",
                  "pm.environment.set(\"token\", jsonData[\"jwt-token\"]);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
