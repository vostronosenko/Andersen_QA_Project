                  "let date = moment()\r",
                  "    .subtract(5, 'years')\r",
                  "    .subtract(7, 'months')\r",
                  "    .subtract(23, 'days')\r",
                  "    .format(\"DD.MM.YYYY\");\r",
                  "\r",
                  "pm.environment.set(\"taskDate\", date);\r",
